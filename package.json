{
  "name": "flaglint",
  "version": "0.5.1",
  "description": "LaunchDarkly Node.js server SDK -> OpenFeature migration.",
  "type": "module",
  "bin": {
    "flaglint": "dist/bin/flaglint.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "feature-flags",
    "launchdarkly",
    "openfeature",
    "cli",
    "flag-debt",
    "developer-tools"
  ],
  "author": "flaglint",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaglint/flaglint.git"
  },
  "homepage": "https://flaglint.dev",
  "bugs": {
    "url": "https://github.com/flaglint/flaglint/issues"
  },
  "scripts": {
    "sync:www": "tsx scripts/sync-www.ts",
    "build": "npm run sync:www && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:agent": "tsc --project tsconfig.agent.json",
    "pretest": "npm run build",
    "test": "vitest",
    "pretest:run": "npm run build",
    "test:run": "vitest run",
    "pretest:coverage": "npm run build",
    "test:coverage": "vitest run --coverage",
    "new-branch": "tsx scripts/new-branch.ts",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major"
  },
  "dependencies": {
    "@typescript-eslint/types": "^8.59.4",
    "@typescript-eslint/typescript-estree": "^8.59.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "micromatch": "^4.0.8",
    "ora": "^8.1.0",
    "p-limit": "^7.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "clipboardy": "^4.0.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  }
}
