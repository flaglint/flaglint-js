---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlagLint — Find every LaunchDarkly SDK call. Migrate safely.</title>
  <meta name="description" content="FlagLint is a free, open-source CLI that finds every direct LaunchDarkly Node.js SDK call in your codebase, ranks them by migration risk, and generates safe OpenFeature rewrites.">
  <meta property="og:title" content="FlagLint — Find every LaunchDarkly SDK call. Migrate safely.">
  <meta property="og:description" content="Free CLI. One command. Every direct LaunchDarkly SDK call in your Node.js codebase, ranked by migration risk. No API key. No source upload.">
  <meta property="og:url" content="https://flaglint.dev">
  <meta property="og:site_name" content="FlagLint">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://flaglint.dev/og.svg">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@flaglintdev">
  <link rel="canonical" href="https://flaglint.dev">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style is:global>
    /* ── Reset ────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design tokens ─────────────────────────────────────────────────── */
    :root {
      --bg:            #080a0a;
      --surface:       #101313;
      --surface-raised:#171b1b;
      --surface-soft:  #0d1117;
      --border:        #26302d;
      --border-strong: #35443e;
      --text:          #f2f5f3;
      --muted:         #b3bcb8;
      --subtle:        #7f8b86;
      --accent:        #00d97e;
      --accent-soft:   rgba(0,217,126,0.13);
      --warning:       #f2b84b;
      --danger:        #ff6b6b;
      --radius:        8px;
      --shadow:        0 24px 80px rgba(0,0,0,0.36);
      --nav-height:    64px;
    }

    /* ── Light mode ─────────────────────────────────────────────────── */
    [data-theme="light"] {
      --bg:            #f8fafb;
      --surface:       #ffffff;
      --surface-raised:#f0f4f7;
      --surface-soft:  #eef2f5;
      --border:        #d1dbe3;
      --border-strong: #b0c0cc;
      --text:          #0f1a14;
      --muted:         #3d5a4a;
      --subtle:        #6b8a7a;
      --accent:        #007a49;
      --accent-soft:   rgba(0,122,73,0.10);
      --warning:       #b45309;
      --danger:        #dc2626;
      --shadow:        0 24px 80px rgba(0,0,0,0.10);
    }
    [data-theme="light"] body {
      background: linear-gradient(180deg,#f0fdf6 0%,#f8fafb 30%,#f8fafb 100%);
    }
    [data-theme="light"] body::before {
      background-image:
        linear-gradient(rgba(0,0,0,0.04) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,0.04) 1px,transparent 1px);
    }
    [data-theme="light"] nav {
      background: rgba(248,250,251,0.92);
      border-bottom-color: rgba(0,0,0,0.08);
    }
    [data-theme="light"] .github-btn { color: var(--text); }
    [data-theme="light"] .proof-shell {
      background: linear-gradient(180deg,#fff,#f8fafb);
    }
    /* Terminal stays dark in light mode — it's a terminal */
    [data-theme="light"] .terminal-body { background: #161b22; }

    /* ── Base ────────────────────────────────────────────────────────── */
    html { scroll-behavior: smooth; }
    body {
      background:
        radial-gradient(circle at 18% 10%,rgba(0,217,126,0.08),transparent 26%),
        linear-gradient(180deg,#080a0a 0%,#0b0d0d 48%,#080a0a 100%);
      color: var(--text);
      font-family: Inter,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      line-height: 1.6;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      background-image:
        linear-gradient(rgba(255,255,255,0.035) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,0.035) 1px,transparent 1px);
      background-size: 40px 40px;
      mask-image: linear-gradient(to bottom,#000 0%,transparent 88%);
    }
    a { color: inherit; text-decoration: none; }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    code, pre {
      font-family: "SF Mono","Cascadia Code","Fira Code",ui-monospace,monospace;
    }

    /* ── Nav ─────────────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(8,10,10,0.88);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(16px);
    }
    .nav-inner {
      max-width: 1180px;
      margin: 0 auto;
      min-height: var(--nav-height);
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .logo { font-size: 20px; font-weight: 800; letter-spacing: 0; }
    .logo span { color: var(--accent); }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }
    .nav-links a:hover { color: var(--text); }
    .github-btn {
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text);
      background: rgba(255,255,255,0.03);
    }
    .nav-search {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 10px;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      transition: border-color 0.15s,color 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .nav-search:hover { border-color: var(--accent); color: var(--text); }
    .nav-search kbd {
      font-size: 11px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 1px 4px;
      font-family: inherit;
      line-height: 1.4;
    }

    /* ── Theme toggle ────────────────────────────────────────────────── */
    .theme-toggle {
      display: flex;
      align-items: center;
      gap: 2px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 2px;
      flex-shrink: 0;
    }
    .theme-btn {
      background: none;
      border: none;
      border-radius: 4px;
      padding: 4px 8px;
      cursor: pointer;
      color: var(--muted);
      font-size: 12px;
      font-family: inherit;
      display: flex;
      align-items: center;
      transition: background 0.1s,color 0.1s;
      line-height: 1;
    }
    .theme-btn.active,
    .theme-btn:hover { background: var(--accent); color: #fff; }
    [data-theme="light"] .theme-btn.active,
    [data-theme="light"] .theme-btn:hover { color: #fff; }

    /* ── Layout utilities ────────────────────────────────────────────── */
    main { display: block; }
    section { padding: 88px 24px; }
    .section-inner { max-width: 1180px; margin: 0 auto; }
    .section-kicker {
      color: var(--accent);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .section-heading {
      font-size: clamp(28px,3.8vw,44px);
      line-height: 1.12;
      letter-spacing: -0.01em;
      margin-bottom: 16px;
    }
    .section-copy {
      max-width: 680px;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.7;
    }
    .section-copy code {
      font-size: 14px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      color: var(--accent);
    }
    [data-theme="light"] .section-copy code {
      background: #e8f2ec;
      border-color: #b8d4c4;
    }

    /* ── Buttons ─────────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 7px;
      font-weight: 700;
      border: 1px solid transparent;
      cursor: pointer;
      text-decoration: none;
      transition: opacity 0.15s,transform 0.1s;
    }
    .btn:hover { opacity: 0.9; }
    .btn:active { transform: scale(0.98); }
    .btn-primary { background: var(--accent); color: #02100a; }
    .btn-lg { min-height: 50px; padding: 13px 28px; font-size: 15px; }
    .btn-sm {
      min-height: 38px;
      padding: 8px 16px;
      font-size: 13px;
      background: rgba(255,255,255,0.04);
      color: var(--text);
      border-color: var(--border);
    }
    [data-theme="light"] .btn-sm {
      background: var(--surface);
      border-color: var(--border);
    }

    /* ── Terminal / proof-shell ──────────────────────────────────────── */
    .proof-shell {
      background: linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.02));
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .terminal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 13px 16px;
      border-bottom: 1px solid var(--border);
      background: rgba(0,0,0,0.28);
    }
    .dots { display: flex; gap: 7px; }
    .dot { width: 11px; height: 11px; border-radius: 50%; }
    .dot.red   { background: #ff5f57; }
    .dot.yellow{ background: #febc2e; }
    .dot.green { background: #28c840; }
    .term-version { color: var(--subtle); font-size: 12px; white-space: nowrap; }
    .terminal-body {
      padding: 18px 20px;
      background: #0d1117;
      overflow-x: auto;
    }
    .terminal-body pre {
      color: #cdd9d4;
      font-size: 12.5px;
      line-height: 1.7;
      white-space: pre;
      min-width: 0;
    }
    /* Semantic colours inside terminal */
    .t-dim    { color: #5a706a; }
    .t-green  { color: #3dd68c; }
    .t-amber  { color: #e8a628; }
    .t-red    { color: #f87171; }
    .t-white  { color: #e2e8e4; }

    /* ── Hero ────────────────────────────────────────────────────────── */
    .hero { padding: 100px 24px 80px; }
    .hero-grid {
      max-width: 1180px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0,1fr) minmax(0,1fr);
      gap: 60px;
      align-items: center;
    }
    .hero-grid > * { min-width: 0; }
    .hero h1 {
      font-size: clamp(36px,3.4vw,50px);
      line-height: 1.08;
      letter-spacing: -0.025em;
      margin-bottom: 18px;
    }
    .hero-body {
      color: var(--muted);
      font-size: 18px;
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 32px;
    }
    .hero-cta-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .command-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 14px;
      color: var(--accent);
      font-size: 13px;
      font-family: "SF Mono","Cascadia Code","Fira Code",ui-monospace,monospace;
      cursor: pointer;
      transition: border-color 0.15s;
      max-width: 100%;
      overflow: hidden;
    }
    .command-pill:hover { border-color: var(--accent); }
    .command-pill .dollar { color: var(--subtle); }
    [data-theme="light"] .command-pill {
      background: #f0f4f2;
      border-color: #c8d8ce;
    }
    .trust-strip {
      font-size: 12px;
      font-weight: 500;
      color: var(--subtle);
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      align-items: center;
    }
    .trust-strip .sep { color: var(--border-strong); }

    /* ── Section: Proof (argument-order problem) ─────────────────────── */
    .section-proof {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    [data-theme="light"] .section-proof {
      background: #f4f8f6;
    }
    .diff-grid {
      display: grid;
      grid-template-columns: 1fr 56px 1fr;
      gap: 0;
      align-items: start;
      margin-top: 40px;
    }
    .diff-grid > * { min-width: 0; }
    .diff-panel {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    [data-theme="light"] .diff-panel {
      background: var(--surface);
    }
    .diff-label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: rgba(0,0,0,0.22);
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    [data-theme="light"] .diff-label {
      background: rgba(0,0,0,0.05);
    }
    .diff-label .badge {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.06em;
    }
    .badge-before { background: rgba(255,107,107,0.18); color: #ff8080; }
    .badge-after  { background: rgba(0,217,126,0.15);  color: var(--accent); }
    [data-theme="light"] .badge-before { background: #fde8e8; color: var(--danger); }
    [data-theme="light"] .badge-after  { background: #d4f5e6; color: #005c33; }
    .diff-filename {
      padding: 8px 16px;
      background: rgba(0,0,0,0.14);
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      font-family: "SF Mono","Cascadia Code","Fira Code",ui-monospace,monospace;
      color: var(--subtle);
    }
    [data-theme="light"] .diff-filename {
      background: rgba(0,0,0,0.04);
      color: #46554d;
    }
    .arch-pre {
      margin: 0;
      padding: 18px 20px;
      font-size: 12.5px;
      line-height: 1.8;
      color: #cdd9d4;
      overflow-x: auto;
      background: var(--surface-soft);
      white-space: pre;
    }
    [data-theme="light"] .arch-pre {
      color: #1e3a2e;
      background: #f0f4f2;
    }
    .arch-hi-red   { color: #f87171; }
    .arch-hi-green { color: #3dd68c; }
    .arch-dim      { color: #4e6660; }
    [data-theme="light"] .arch-hi-red   { color: #c53030; }
    [data-theme="light"] .arch-hi-green { color: #005c33; }
    [data-theme="light"] .arch-dim      { color: #7f8b86; }
    .diff-note {
      margin-top: 10px;
      padding: 10px 14px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.55;
    }
    .diff-callout {
      margin: 10px 0 0;
      padding: 11px 16px;
      background: var(--surface-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.55;
    }
    [data-theme="light"] .diff-callout {
      background: #e8f2ec;
      border-color: #b8d4c4;
    }
    .diff-callout strong { color: var(--text); }
    .diff-arrow-col {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 80px;
    }
    .diff-arrow {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--accent-soft);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      font-size: 16px;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* ── Section: Workflow ────────────────────────────────────────────── */
    .workflow-strip {
      display: grid;
      grid-template-columns: 1fr 40px 1fr 40px 1fr;
      margin-top: 44px;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      background: var(--surface);
    }
    .workflow-strip > * { min-width: 0; }
    .wf-step { padding: 32px 28px; }
    .wf-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--surface);
      border-left: 1px solid var(--border);
      border-right: 1px solid var(--border);
      color: var(--subtle);
      font-size: 18px;
    }
    .wf-num {
      display: inline-flex;
      width: 30px;
      height: 30px;
      align-items: center;
      justify-content: center;
      background: var(--accent-soft);
      color: var(--accent);
      border-radius: 50%;
      font-size: 13px;
      font-weight: 800;
      margin-bottom: 14px;
    }
    .wf-step h3 {
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 8px;
      letter-spacing: -0.01em;
    }
    .wf-step p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    /* Command code blocks inside workflow steps */
    .cmd {
      display: block;
      width: 100%;
      margin-top: 8px;
      padding: 9px 13px;
      background: var(--surface-soft);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--accent);
      font-family: "SF Mono","Cascadia Code","Fira Code",ui-monospace,monospace;
      font-size: 11.5px;
      line-height: 1.5;
      white-space: nowrap;
      overflow-x: auto;
      box-sizing: border-box;
    }
    [data-theme="light"] .cmd {
      background: #edf5f0;
      border-color: #c0d8ca;
    }

    /* ── Section: Docs cards ─────────────────────────────────────────── */
    .docs-section {
      background: linear-gradient(180deg,rgba(0,217,126,0.06),transparent);
    }
    [data-theme="light"] .docs-section {
      background: linear-gradient(180deg,rgba(0,122,73,0.05),transparent);
    }
    .docs-grid {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 16px;
      margin-top: 36px;
    }
    .doc-card {
      display: block;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      text-decoration: none;
      transition: border-color 0.15s,transform 0.15s;
    }
    .doc-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }
    .doc-card h3 {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 7px;
      letter-spacing: -0.01em;
    }
    .doc-card p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
    }
    .doc-card .card-arrow {
      display: inline-block;
      margin-top: 12px;
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
    }

    /* ── Footer ──────────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 28px 24px;
      color: var(--subtle);
      font-size: 13px;
    }
    .footer-inner {
      max-width: 1180px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-links {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }
    .footer-links a:hover { color: var(--text); }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @media (max-width: 980px) {
      .hero-grid { grid-template-columns: 1fr; gap: 40px; }
      .diff-grid { grid-template-columns: 1fr; }
      .diff-arrow-col { display: none; }
      .workflow-strip { grid-template-columns: 1fr; }
      .wf-divider { display: none; }
      .wf-step { border-bottom: 1px solid var(--border); }
      .wf-step:last-of-type { border-bottom: none; }
    }
    @media (max-width: 680px) {
      section { padding: 64px 18px; }
      .hero { padding: 72px 18px 56px; }
      .hero h1 { font-size: clamp(30px,7vw,40px); }
      .docs-grid { grid-template-columns: 1fr; }
      .nav-links a:not(.github-btn):not(.nav-search) { display: none; }
      .nav-inner { padding: 0 18px; }
      .search-label,.nav-search kbd { display: none; }
      .hero-cta-row { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <!-- Inline theme init — runs before paint to prevent flash -->
  <script>(function(){var s=localStorage.getItem('flaglint-theme')||'dark';var r=s==='auto'?(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'):s;document.documentElement.setAttribute('data-theme',r);})();</script>

  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "FlagLint",
  "description": "Free, open-source CLI that finds every direct LaunchDarkly Node.js SDK call, ranks them by migration risk, and generates safe OpenFeature rewrites.",
  "url": "https://flaglint.dev",
  "downloadUrl": "https://www.npmjs.com/package/flaglint",
  "softwareVersion": "0.6.0",
