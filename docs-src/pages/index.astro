  <!-- ── JS: theme toggle + search shortcut ────────────────────────── -->
  <script>
  (function() {
    var STORAGE_KEY = 'flaglint-theme';

    function getSystemTheme() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(preference) {
      var resolved = preference === 'auto' ? getSystemTheme() : preference;
      document.documentElement.setAttribute('data-theme', resolved);
      localStorage.setItem(STORAGE_KEY, preference);
      document.querySelectorAll('.theme-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.themeValue === preference);
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      applyTheme(localStorage.getItem(STORAGE_KEY) || 'dark');

      document.querySelectorAll('.theme-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { applyTheme(btn.dataset.themeValue); });
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
        if (localStorage.getItem(STORAGE_KEY) === 'auto') applyTheme('auto');
      });

      // Search button → docs
      var searchBtn = document.getElementById('nav-search-btn');
      if (searchBtn) {
        searchBtn.addEventListener('click', function(e) {
          e.preventDefault();
          window.location.href = '/docs/';
        });
      }

      // ⌘K / Ctrl+K opens docs search
      document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          window.location.href = '/docs/';
        }
      });

      // Command pill: copy to clipboard on click
      document.querySelectorAll('.command-pill').forEach(function(pill) {
        pill.addEventListener('click', function() {
          var cmd = pill.querySelector('code');
          if (cmd && navigator.clipboard) {
            navigator.clipboard.writeText(cmd.textContent.trim()).then(function() {
              var orig = pill.dataset.orig || pill.innerHTML;
              pill.dataset.orig = orig;
              pill.innerHTML = '<span style="color:var(--accent)">✓ Copied!</span>';
              setTimeout(function() { pill.innerHTML = orig; }, 1800);
            });
          }
        });
        pill.title = 'Click to copy';
        pill.style.cursor = 'pointer';
      });
    });
  })();
  </script>
