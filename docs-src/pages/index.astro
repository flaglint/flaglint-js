    <section>
      <div class="section-inner">
        <div class="section-kicker">Supported scope</div>
        <h2 class="section-heading">Focused automation, explicit manual review.</h2>
        <div class="scope-table">
          <div class="card">
            <div class="scope-label">Auto-migrated</div>
            <ul>
              <li>Static `boolVariation`, `stringVariation`, `numberVariation`, and `jsonVariation` calls.</li>
              <li>Generic `variation` only when fallback type is proven.</li>
              <li>Call sites with proven OpenFeature client bindings.</li>
            </ul>
          </div>
          <div class="card">
            <div class="scope-label">Detected / manual review</div>
            <ul>
              <li>Dynamic keys.</li>
              <li>Detail evaluations.</li>
              <li>Bulk calls like `allFlagsState`.</li>
              <li>Configured wrappers and ambiguous bindings.</li>
            </ul>
          </div>
          <div class="card">
            <div class="scope-label">Outside coverage</div>
            <ul>
              <li>Browser SDKs and React SDKs.</li>
              <li>Non-Node SDKs.</li>
              <li>Non-LaunchDarkly providers.</li>
              <li>Production stale-flag detection.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

