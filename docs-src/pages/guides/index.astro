---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Migration Guides | FlagLint</title>
  <meta name="description" content="Practical guides for migrating LaunchDarkly Node.js SDK usage to OpenFeature safely.">
  <meta property="og:title" content="Migration Guides | FlagLint">
  <meta property="og:description" content="Practical guides for migrating LaunchDarkly Node.js SDK usage to OpenFeature safely.">
  <meta property="og:url" content="https://flaglint.dev/guides/">
  <meta property="og:site_name" content="FlagLint">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://flaglint.dev/og.svg">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="canonical" href="https://flaglint.dev/guides/">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface-raised: #1a1a1a;
      --surface-soft: #0d1117;
      --border: #222222;
      --border-strong: #333333;
      --text: #f0f0f0;
      --text-primary: #f0f0f0;
      --text-secondary: #999999;
      --muted: #999999;
      --subtle: #666666;
      --accent: #00d97e;
      --accent-soft: rgba(0, 217, 126, 0.10);
      --code-bg: #0d1117;
      --radius: 8px;
      --transition: 0.15s ease;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 16px;
      line-height: 1.65;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 24px;
      min-height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .logo { font-size: 18px; font-weight: 700; color: var(--text-primary); text-decoration: none; }
    .nav-links {
      display: flex;
      gap: 22px;
      align-items: center;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }
    .nav-links a { color: var(--muted); }
    .nav-links a:hover { color: var(--text-primary); text-decoration: none; }
    .nav-links a.active { color: var(--text-primary); }
    .github-btn {
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text-primary);
      background: rgba(255,255,255,0.03);
    }
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 56px 24px 96px;
    }
    .breadcrumb { font-size: 13px; color: var(--text-secondary); margin-bottom: 32px; }
    .breadcrumb a { color: var(--text-secondary); }
    .breadcrumb a:hover { color: var(--text-primary); }
    .breadcrumb .sep { margin: 0 8px; color: #444; }
    h1 { font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 12px; }
    .page-tagline { font-size: 17px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 48px; }
    p { color: var(--text-secondary); line-height: 1.75; margin-bottom: 16px; }
    p strong { color: var(--text-primary); }

    /* Guide card */
    .guides-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .guide-card {
      display: block;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px 28px;
      text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
      position: relative;
    }
    .guide-card:hover {
      border-color: var(--accent);
      background: var(--surface-raised);
      text-decoration: none;
    }
    .guide-card:hover .guide-arrow { color: var(--accent); transform: translateX(3px); }
    .guide-card-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 10px;
    }
    .guide-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.35;
    }
    .guide-arrow {
      font-size: 20px;
      color: var(--subtle);
      flex-shrink: 0;
      transition: color 0.15s, transform 0.15s;
      margin-top: 2px;
    }
    .guide-description {
      font-size: 14.5px;
      color: var(--text-secondary);
      line-height: 1.65;
      margin-bottom: 16px;
    }
    .guide-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .guide-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .guide-tag {
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 4px;
      background: var(--surface-raised);
      border: 1px solid var(--border-strong);
      color: var(--muted);
    }
    .guide-updated {
      font-size: 12px;
      color: var(--subtle);
      margin-left: auto;
    }
    .guide-verified {
      font-size: 11px;
      font-weight: 600;
      color: var(--accent);
      background: var(--accent-soft);
      border: 1px solid rgba(0,217,126,0.2);
      border-radius: 4px;
      padding: 2px 8px;
    }

    /* Footer */
    footer {
      border-top: 1px solid var(--border); padding: 28px 24px;
      max-width: 1180px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 13px; color: #555; }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 13px; color: #666; transition: color var(--transition); }
    .footer-links a:hover { color: var(--text-primary); text-decoration: none; }

    /* Light mode */
    [data-theme="light"] {
      --bg: #f8fafb;
      --surface: #ffffff;
      --surface-raised: #f0f4f7;
      --surface-soft: #eef2f5;
      --border: #d1dbe3;
      --border-strong: #b0c0cc;
      --text: #0f1a14;
      --text-primary: #0f1a14;
      --text-secondary: #3d5a4a;
      --muted: #3d5a4a;
      --subtle: #6b8a7a;
      --accent: #007a49;
      --accent-soft: rgba(0, 122, 73, 0.10);
    }
    [data-theme="light"] nav {
      background: rgba(248,250,251,0.92);
      border-bottom-color: rgba(0,0,0,0.08);
    }
    [data-theme="light"] .github-btn { color: var(--text-primary); }
    [data-theme="light"] body {
      background: linear-gradient(180deg, #f0fdf6 0%, #f8fafb 30%, #f8fafb 100%);
    }

    /* Theme toggle */
    .theme-toggle {
      display: flex; align-items: center; gap: 2px;
      background: var(--surface-raised); border: 1px solid var(--border);
      border-radius: 6px; padding: 2px; flex-shrink: 0;
    }
    .theme-btn {
      background: none; border: none; border-radius: 4px; padding: 4px 8px;
      cursor: pointer; color: var(--muted); font-size: 12px; font-family: inherit;
      display: flex; align-items: center; transition: background 0.1s, color 0.1s; line-height: 1;
    }
    .theme-btn.active, .theme-btn:hover { background: var(--accent); color: #fff; }

    @media (max-width: 680px) {
      .nav-links a:not(.github-btn) { display: none; }
      .nav-inner { padding: 0 18px; }
      .guide-updated { display: none; }
    }
  </style>
  <script>(function(){var s=localStorage.getItem('flaglint-theme')||'dark';var r=s==='auto'?(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'):s;document.documentElement.setAttribute('data-theme',r);})();</script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="FlagLint">FlagLint</a>
    <div class="nav-links" aria-label="Primary navigation">
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/guides/" class="active">Guides</a>
      <div class="theme-toggle" role="group" aria-label="Select theme">
        <button class="theme-btn" data-theme-value="light" title="Light mode" aria-label="Light mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zm0-2a1 1 0 0 0 1-1V2a1 1 0 0 0-2 0v2a1 1 0 0 0 1 1zm0 14a1 1 0 0 0-1 1v2a1 1 0 0 0 2 0v-2a1 1 0 0 0-1-1zm9-8h-2a1 1 0 0 0 0 2h2a1 1 0 0 0 0-2zM5 12a1 1 0 0 0-1-1H2a1 1 0 0 0 0 2h2a1 1 0 0 0 1-1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="dark" title="Dark mode" aria-label="Dark mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="auto" title="Auto (system)" aria-label="Auto theme">Auto</button>
      </div>
      <a class="github-btn" href="https://github.com/flaglint/flaglint" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</nav>

<main>
  <div class="breadcrumb">
    <a href="/">FlagLint</a>
    <span class="sep">›</span>
    <span>Guides</span>
  </div>

  <h1>Migration Guides</h1>
  <p class="page-tagline">Step-by-step guides for safe LaunchDarkly to OpenFeature migrations.</p>

  <div class="guides-grid">
    <a href="/guides/launchdarkly-to-openfeature-nodejs/" class="guide-card">
      <div class="guide-card-head">
        <div class="guide-title">LaunchDarkly to OpenFeature: Node.js Migration Guide</div>
        <span class="guide-arrow" aria-hidden="true">→</span>
      </div>
      <p class="guide-description">
        Migrate direct LaunchDarkly Node.js SDK calls to OpenFeature safely. Understand the
        argument-order risk that a naive search-and-replace misses, classify your call sites
        by automation safety, and apply proven rewrites with FlagLint.
      </p>
      <div class="guide-meta">
        <div class="guide-tags">
          <span class="guide-tag">Node.js</span>
          <span class="guide-tag">OpenFeature</span>
          <span class="guide-tag">LaunchDarkly</span>
        </div>
        <span class="guide-verified">Verified · v0.9.0</span>
        <span class="guide-updated">Updated 2026-06-07</span>
      </div>
    </a>
  </div>
</main>

<footer>
  <span class="footer-copy">© 2026 FlagLint — MIT License</span>
  <div class="footer-links">
    <a href="https://github.com/flaglint/flaglint" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://www.npmjs.com/package/flaglint" target="_blank" rel="noopener noreferrer">npm</a>
    <a href="/trust">Security &amp; Trust</a>
    <a href="/privacy">Privacy</a>
    <a href="https://github.com/flaglint/flaglint/issues" target="_blank" rel="noopener noreferrer">Contact</a>
  </div>
</footer>

<script>
(function() {
  var STORAGE_KEY = 'flaglint-theme';

  function getSystemTheme() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(preference) {
    var resolved = preference === 'auto' ? getSystemTheme() : preference;
    document.documentElement.setAttribute('data-theme', resolved);
    localStorage.setItem(STORAGE_KEY, preference);
    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.themeValue === preference);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var saved = localStorage.getItem(STORAGE_KEY) || 'dark';
    applyTheme(saved);

    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { applyTheme(btn.dataset.themeValue); });
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
      if (localStorage.getItem(STORAGE_KEY) === 'auto') applyTheme('auto');
    });
  });
})();
</script>
</body>
</html>
