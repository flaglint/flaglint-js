  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface-raised: #1a1a1a;
      --surface-soft: #0d1117;
      --border: #222222;
      --border-strong: #333333;
      --text: #f0f0f0;
      --text-primary: #f0f0f0;
      --text-secondary: #999999;
      --muted: #999999;
      --subtle: #666666;
      --accent: #00d97e;
      --accent-soft: rgba(0, 217, 126, 0.10);
      --code-bg: #0d1117;
      --radius: 8px;
      --transition: 0.15s ease;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text-primary);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 16px;
      line-height: 1.65;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    a:focus-visible, button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 24px;
      min-height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .logo { font-size: 18px; font-weight: 700; color: var(--text-primary); text-decoration: none; }
    .nav-links {
      display: flex;
      gap: 22px;
      align-items: center;
      color: var(--muted);
      font-size: 14px;
      font-weight: 600;
    }
    .nav-links a { color: var(--muted); }
    .nav-links a:hover { color: var(--text-primary); text-decoration: none; }
    .github-btn {
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text-primary);
      background: rgba(255,255,255,0.03);
    }
    .breadcrumb { font-size: 13px; color: var(--text-secondary); margin-bottom: 32px; }
    .breadcrumb a { color: var(--text-secondary); }
    .breadcrumb a:hover { color: var(--text-primary); }
    .breadcrumb .sep { margin: 0 8px; color: #444; }

    /* Two-column layout */
    .page-wrap {
      max-width: 1080px;
      margin: 0 auto;
      padding: 48px 24px 96px;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 48px;
      align-items: start;
    }
    .toc-col {
      position: sticky;
      top: 80px;
    }
    .toc-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--subtle);
      margin-bottom: 12px;
    }
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      border-left: 1px solid var(--border);
    }
    .toc-list li { margin-bottom: 2px; }
    .toc-list a {
      display: block;
      padding: 5px 0 5px 14px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.4;
      border-left: 2px solid transparent;
      margin-left: -1px;
    }
    .toc-list a:hover {
      color: var(--text-primary);
      border-left-color: var(--accent);
      text-decoration: none;
    }
    .toc-list a.active {
      color: var(--accent);
      border-left-color: var(--accent);
    }
    .article-col { max-width: 720px; }

    /* Article typography */
    h1 { font-size: clamp(26px, 3.5vw, 38px); font-weight: 700; line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 16px; }
    .article-meta { font-size: 13px; color: var(--subtle); margin-bottom: 40px; display: flex; gap: 20px; flex-wrap: wrap; }
    h2 {
      font-size: 22px; font-weight: 700; margin: 52px 0 14px;
      color: var(--text-primary); scroll-margin-top: 88px;
      padding-top: 4px;
    }
    h2:first-of-type { margin-top: 0; }
    h3 { font-size: 17px; font-weight: 700; margin: 28px 0 10px; color: var(--text-primary); }
    p { color: var(--text-secondary); line-height: 1.75; margin-bottom: 16px; }
    p strong { color: var(--text-primary); }
    ul, ol { padding-left: 22px; color: var(--text-secondary); line-height: 1.75; margin-bottom: 16px; }
    li { margin-bottom: 6px; }
    li strong { color: var(--text-primary); }
    code {
      font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px;
      background: var(--code-bg); border: 1px solid #30363d; border-radius: 3px;
      padding: 1px 5px; color: #a5d6ff;
    }

    /* Code blocks */
    .code-block {
      position: relative;
      background: var(--code-bg);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius);
      margin: 20px 0;
    }
    .code-block-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px;
      border-bottom: 1px solid var(--border);
      font-size: 12px;
      color: var(--subtle);
    }
    .code-block pre {
      margin: 0;
      padding: 16px;
      overflow-x: auto;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 13.5px;
      line-height: 1.6;
      color: #e6edf3;
    }
    .copy-btn {
      background: transparent;
      border: 1px solid var(--border-strong);
      border-radius: 4px;
      padding: 3px 9px;
      font-size: 11px;
      color: var(--muted);
      cursor: pointer;
      font-family: inherit;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .copy-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-soft); }
    .copy-btn.copied { border-color: var(--accent); color: var(--accent); background: var(--accent-soft); }

    /* Diff coloring */
    .diff-add { color: #7ee787; }
    .diff-remove { color: #f85149; }
    .diff-meta { color: var(--subtle); }
    .diff-comment { color: #8b949e; font-style: italic; }

    /* Callout */
    .callout {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 16px 20px;
      margin: 24px 0;
      font-size: 14.5px;
      color: var(--text-secondary);
      line-height: 1.7;
    }
    .callout strong { color: var(--text-primary); }
    .callout.warn { border-left-color: #f0a500; }
    .callout.warn strong { color: #f0c040; }

    /* Architecture flow */
    .arch-flow {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin: 24px 0;
    }
    .arch-row {
      display: flex;
      align-items: stretch;
      gap: 0;
    }
    .arch-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--subtle);
      width: 72px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      padding-right: 12px;
    }
    .arch-blocks {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      padding: 12px 0;
    }
    .arch-block {
      background: var(--surface);
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      padding: 8px 14px;
      font-size: 13px;
      color: var(--text-secondary);
      white-space: nowrap;
    }
    .arch-block.accent {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-soft);
    }
    .arch-arrow {
      font-size: 14px;
      color: var(--subtle);
      padding: 0 2px;
    }
    .arch-divider {
      border: none;
      border-top: 1px dashed var(--border);
      margin: 4px 72px;
    }

    /* Migration step */
    .step-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin: 24px 0;
      overflow: hidden;
    }
    .step-header {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
    }
    .step-num {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--accent);
      color: #000;
      font-size: 13px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .step-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .step-body { padding: 16px 20px 20px; }
    .step-body p { margin-bottom: 10px; }
    .step-body p:last-child { margin-bottom: 0; }
    .step-body ul { margin-bottom: 10px; }

    /* Pattern table */
    .pattern-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin: 20px 0;
    }
    .pattern-table th {
      text-align: left;
      padding: 10px 14px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--subtle);
      border-bottom: 1px solid var(--border-strong);
    }
    .pattern-table td {
      padding: 10px 14px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      line-height: 1.55;
    }
    .pattern-table td:first-child { color: var(--text-primary); font-weight: 500; }
    .pattern-table tr:last-child td { border-bottom: none; }
    .badge-safe { color: #7ee787; font-size: 12px; font-weight: 600; }
    .badge-manual { color: #f0a500; font-size: 12px; font-weight: 600; }
    .badge-config { color: #79c0ff; font-size: 12px; font-weight: 600; }

    /* Fact card */
    .fact-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      margin: 24px 0;
    }
    .fact-card-header {
      padding: 12px 20px;
      background: var(--surface-raised);
      border-bottom: 1px solid var(--border);
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .fact-card-header .verified-badge {
      font-size: 11px;
      font-weight: 600;
      color: var(--accent);
      background: var(--accent-soft);
      border: 1px solid rgba(0,217,126,0.2);
      border-radius: 4px;
      padding: 2px 8px;
    }
    .fact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
    .fact-cell {
      padding: 12px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .fact-cell:nth-child(odd) { border-right: 1px solid var(--border); }
    .fact-cell:nth-last-child(-n+2) { border-bottom: none; }
    .fact-key { font-size: 13px; color: var(--muted); }
    .fact-val { font-size: 14px; font-weight: 700; color: var(--text-primary); }
    .fact-val.accent { color: var(--accent); }

    /* Example block */
    .example-block {
      margin: 28px 0;
    }
    .example-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 10px;
    }
    .example-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: 8px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .tag-rewritten { background: rgba(126,231,135,0.12); color: #7ee787; }
    .tag-skipped { background: rgba(240,165,0,0.12); color: #f0a500; }

    /* Provider boundary */
    .boundary-list {
      list-style: none;
      padding: 0;
      margin: 20px 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .boundary-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 14px;
    }
    .boundary-item-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      margin-top: 1px;
    }
    .boundary-item-icon.auto { background: var(--accent-soft); color: var(--accent); }
    .boundary-item-icon.manual { background: rgba(240,165,0,0.12); color: #f0a500; }
    .boundary-item-label { color: var(--text-primary); font-weight: 600; }
    .boundary-item-sub { color: var(--muted); font-size: 13px; margin-top: 1px; }

    /* CTA */
    .cta-primary {
      background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin: 32px 0;
    }
    .cta-secondary {
      background: var(--surface-raised);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin: 24px 0;
    }
    .cta-secondary h3 { margin: 0 0 8px; }
    .cta-secondary p { margin-bottom: 12px; }
    .cta-privacy-note { font-size: 12px; color: var(--subtle); margin-top: 8px; }

    .article-links {
      border-top: 1px solid var(--border);
      margin-top: 48px;
      padding-top: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      font-size: 13.5px;
    }
    .article-links a { color: var(--muted); }
    .article-links a:hover { color: var(--accent); }
    .article-links .sep { color: var(--border-strong); }

    /* Footer */
    footer {
      border-top: 1px solid var(--border); padding: 28px 24px;
      max-width: 1180px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 13px; color: #555; }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: 13px; color: #666; transition: color var(--transition); }
    .footer-links a:hover { color: var(--text-primary); text-decoration: none; }

    /* Light mode */
    [data-theme="light"] {
      --bg: #f8fafb;
      --surface: #ffffff;
      --surface-raised: #f0f4f7;
      --surface-soft: #eef2f5;
      --border: #d1dbe3;
      --border-strong: #b0c0cc;
      --text: #0f1a14;
      --text-primary: #0f1a14;
      --text-secondary: #3d5a4a;
      --muted: #3d5a4a;
      --subtle: #6b8a7a;
      --accent: #007a49;
      --accent-soft: rgba(0, 122, 73, 0.10);
    }
    [data-theme="light"] nav {
      background: rgba(248,250,251,0.92);
      border-bottom-color: rgba(0,0,0,0.08);
    }
    [data-theme="light"] .github-btn { color: var(--text-primary); }
    [data-theme="light"] body {
      background: linear-gradient(180deg, #f0fdf6 0%, #f8fafb 30%, #f8fafb 100%);
    }

    /* Theme toggle */
    .theme-toggle {
      display: flex; align-items: center; gap: 2px;
      background: var(--surface-raised); border: 1px solid var(--border);
      border-radius: 6px; padding: 2px; flex-shrink: 0;
    }
    .theme-btn {
      background: none; border: none; border-radius: 4px; padding: 4px 8px;
      cursor: pointer; color: var(--muted); font-size: 12px; font-family: inherit;
      display: flex; align-items: center; transition: background 0.1s, color 0.1s; line-height: 1;
    }
    .theme-btn.active, .theme-btn:hover { background: var(--accent); color: #fff; }

    @media (max-width: 860px) {
      .page-wrap {
        grid-template-columns: 1fr;
        gap: 0;
      }
      .toc-col {
        position: static;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 40px;
      }
      .toc-list { border-left: none; display: flex; flex-wrap: wrap; gap: 4px; }
      .toc-list a { border-left: none; border: 1px solid var(--border); border-radius: 4px; padding: 4px 10px; }
      .toc-list a:hover { border-color: var(--accent); }
    }
    @media (max-width: 680px) {
      .nav-links a:not(.github-btn) { display: none; }
      .nav-inner { padding: 0 18px; }
      .fact-grid { grid-template-columns: 1fr; }
      .fact-cell:nth-child(odd) { border-right: none; }
      .fact-cell:nth-last-child(-n+2) { border-bottom: 1px solid var(--border); }
      .fact-cell:last-child { border-bottom: none; }
    }
  </style>
  <script>(function(){var s=localStorage.getItem('flaglint-theme')||'dark';var r=s==='auto'?(window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light'):s;document.documentElement.setAttribute('data-theme',r);})();</script>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="FlagLint">FlagLint</a>
    <div class="nav-links" aria-label="Primary navigation">
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/guides/">Guides</a>
      <div class="theme-toggle" role="group" aria-label="Select theme">
        <button class="theme-btn" data-theme-value="light" title="Light mode" aria-label="Light mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7zm0-2a1 1 0 0 0 1-1V2a1 1 0 0 0-2 0v2a1 1 0 0 0 1 1zm0 14a1 1 0 0 0-1 1v2a1 1 0 0 0 2 0v-2a1 1 0 0 0-1-1zm9-8h-2a1 1 0 0 0 0 2h2a1 1 0 0 0 0-2zM5 12a1 1 0 0 0-1-1H2a1 1 0 0 0 0 2h2a1 1 0 0 0 1-1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="dark" title="Dark mode" aria-label="Dark mode">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="auto" title="Auto (system)" aria-label="Auto theme">Auto</button>
      </div>
      <a class="github-btn" href="https://github.com/flaglint/flaglint" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</nav>

<div class="page-wrap">
  <!-- Table of Contents -->
  <aside class="toc-col" aria-label="Table of contents">
    <div class="toc-label">On this page</div>
